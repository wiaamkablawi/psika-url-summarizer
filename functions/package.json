{
  "name": "functions",
  "description": "Cloud Functions scaffold for Firebase",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "lint": "echo 'No lint configured'",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "node -e \"console.log('No functions tests configured yet')\""
  },
  "dependencies": {
    "firebase-functions": "^5.1.1"
  },
  "private": true
}
